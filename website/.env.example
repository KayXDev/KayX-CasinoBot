# Copy this file to `website/.env.local` and fill the missing values.

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Discord OAuth
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Database
DATABASE_URL="mysql://root:@localhost:3306/casino_bot"
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=casino_bot

# Payment / Support
DISCORD_SUPPORT_SERVER=

# Bot
BOT_TOKEN=
DISCORD_BOT_TOKEN=

# Admin
DISCORD_OWNER_ID=
DISCORD_GUILD_ID=
NEXT_PUBLIC_DISCORD_OWNER_ID=
